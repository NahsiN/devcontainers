{
    "name": "pymc-marketing dev env",
    "build": {
        "dockerfile": "Dockerfile"
    },

    // Features
    "features": {
        // "ghcr.io/devcontainers/features/common-utils:2": {
        //     "configureZshAsDefaultShell": true,
        //     "upgradePackages": false,
        //     # set to none because the Dockerfile already has 1000 user
        //     "username": "none"
        // },
       "ghcr.io/stu-bell/devcontainer-features/claude-code:0": {}
    },

    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-toolsai.jupyter",
                "ms-toolsai.vscode-jupyter-cell-tags",
                "ms-toolsai.jupyter-keymap",
                "ms-toolsai.jupyter-renderers",
                "anthropic.claude-code"
            ]
        }
    },

    // the claude code feature is somehow failing on call add_to_user_profiles in install.sh 
    // see https://github.com/stu-bell/devcontainer-features/blob/main/src/claude-code/install.sh
   "postCreateCommand": "echo 'export PATH=\"$HOME/.local/bin:$PATH\"' >> ~/.bashrc",

    "mounts": [
        {
            "source": "pymc-marketing-claude",
            "target": "/home/jovyan/.claude",
            "type": "volume"
        }
    ],

    "containerEnv": {
        "CLAUDE_CONFIG_DIR": "/home/jovyan/.claude",
    },

    // Set `remoteUser` to `root` to connect as root instead. More info: https://aka.ms/vscode-remote/containers/non-root.
    "remoteUser": "jovyan"
    // "remoteUser": "root"
}
