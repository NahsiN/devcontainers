{
    "name": "datascience kaggle dev env",
    "image": "gcr.io/kaggle${templateOption:accelerator}images/python:${templateOption:imageVariant}",

    // Features
    "features": {
        //  docs: https://github.com/devcontainers-extra/features/tree/main/src/zsh-plugins   
        //  "ghcr.io/devcontainers-extra/features/zsh-plugins:0": {}
         "ghcr.io/devcontainers/features/common-utils:2": {
            "configureZshAsDefaultShell": true,
            "upgradePackages": false
        },
        "ghcr.io/iterative/features/dvc:1": {},
        "ghcr.io/rocker-org/devcontainer-features/quarto-cli:1": {
            "version": "latest",
            "installTinyTex": true},
        // uses npm
        // "ghcr.io/devcontainers-extra/features/claude-code:1": {
            // "version": "latest"
        // },  # auto installs the claude code vscode extension    
        // direct install with syntax highlighting
        "ghcr.io/stu-bell/devcontainer-features/claude-code:0": {}
    },

    // 👇 Configure tool-specific properties.
	"customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-toolsai.jupyter",
                "ms-toolsai.vscode-jupyter-cell-tags",
                "ms-toolsai.jupyter-keymap",
                "ms-toolsai.jupyter-renderers",
                // does not install properly in devcontainer
                // "ms-toolsai.jupyter-slideshow",
                "ms-toolsai.tensorboard",
                "anthropic.claude-code"]
        },
        
    },
    
    "mounts": [  
    {  
      "source": "datascience-kaggle-claude",  
      "target": "/home/vscode/.claude",  
      "type": "volume"
    }
    ],

    "containerEnv": {
        "CLAUDE_CONFIG_DIR": "/home/vscode/.claude"
    },


    // 👇 Use 'postCreateCommand' to run commands after the container is created.
	// "postCreateCommand": "cat colab_requirements.txt"
    
    // Set `remoteUser` to `root` to connect as root instead. More info: https://aka.ms/vscode-remote/containers/non-root.
	"remoteUser": "vscode"
}