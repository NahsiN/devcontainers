{
    "id": "datascience-kaggle",
    "version": "1.2.1",
    "name": "Docker Kaggle Image",
    "description": "A datascience development enviorment based of Kaggle's docker images",
    "documentationURL": "https://github.com/NahsiN/devcontainers/tree/main/src/datascience-kaggle",
    "licenseURL": "https://github.com/devcontainers/template-starter/blob/main/LICENSE",
    "options": {
        "imageVariant": {
            "type": "string",
            "description": "image tags: latest, v166, v165, etc. One of the tagged releases from https://github.com/Kaggle/docker-python/releases",
            "proposals": [
                "latest",
                "v166",
                "v165",
                "v164"
            ],
            "default": "latest"
        },
        "accelerator": {
            "type": "string",
            "description": "accelerator choice between cpu `-` and gpu `-gpu-` variants",
            "proposals": [
                "-",
                "-gpu-"
            ],
            "default": "-"
        }
    },
    "platforms": [
        "Any"
    ],
    "publisher": "NahsiN",
    "keywords": [
        "python",
        "datascience",
        "kaggle",
        "julia",
        "r",
        "colab",
        "google colab"
    ]
}